<Application x:Class="DiadiaHeicConverter.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Languages/Strings.zh-Hans.xaml" />
                <ResourceDictionary Source="Resources/Themes/Light.xaml" />
                <ResourceDictionary Source="Resources/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- System font stack: Segoe UI for Latin, Microsoft YaHei UI for CJK -->
            <FontFamily x:Key="AppFontFamily">Segoe UI, Microsoft YaHei UI</FontFamily>
        </ResourceDictionary>
    </Application.Resources>
</Application>
