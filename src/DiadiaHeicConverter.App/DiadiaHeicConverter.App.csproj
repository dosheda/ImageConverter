<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net9.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <PlatformTarget>x64</PlatformTarget>
    <AssemblyName>DiadiaImageConverter</AssemblyName>
    <Product>Diadia Image Converter</Product>
    <ApplicationIcon>Resources\app.ico</ApplicationIcon>
    <Version>0.3.0</Version>
    <Company>dosheda</Company>
    <Copyright>Copyright © 2026 dosheda</Copyright>
  </PropertyGroup>

  <ItemGroup>
    <Resource Include="Resources\app.ico" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.2" />
    <PackageReference Include="Magick.NET-Q16-x64" Version="14.14.0" />
  </ItemGroup>

</Project>
