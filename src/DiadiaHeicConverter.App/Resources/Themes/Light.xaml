<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="WindowBackgroundColor">#F6F7F9</Color>
    <Color x:Key="PanelBackgroundColor">#FFFFFFFF</Color>
    <Color x:Key="TextColor">#111827</Color>
    <Color x:Key="MutedTextColor">#6B7280</Color>
    <Color x:Key="BorderColor">#D7DCE3</Color>
    <Color x:Key="AccentColor">#2563EB</Color>
    <Color x:Key="DropZoneBackgroundColor">#EDF4FF</Color>

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource WindowBackgroundColor}" />
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{StaticResource PanelBackgroundColor}" />
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="{StaticResource MutedTextColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="DropZoneBackgroundBrush" Color="{StaticResource DropZoneBackgroundColor}" />
</ResourceDictionary>
