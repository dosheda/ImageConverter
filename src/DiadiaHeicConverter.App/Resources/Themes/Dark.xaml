<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- ============================================================
         Diadia Image Converter · Dark theme
         Deep slate surfaces with a brighter indigo accent so the
         redesign reads well in low light. Keys mirror Light.xaml.
         ============================================================ -->

    <!-- Surfaces -->
    <Color x:Key="WindowBackgroundColor">#0B1120</Color>
    <Color x:Key="PanelBackgroundColor">#1E293B</Color>
    <Color x:Key="ElevatedBackgroundColor">#243247</Color>
    <Color x:Key="SubtleBackgroundColor">#172033</Color>

    <!-- Text -->
    <Color x:Key="TextColor">#F1F5F9</Color>
    <Color x:Key="MutedTextColor">#94A3B8</Color>
    <Color x:Key="SubtleTextColor">#64748B</Color>

    <!-- Lines -->
    <Color x:Key="BorderColor">#334155</Color>
    <Color x:Key="DividerColor">#273244</Color>

    <!-- Accent (indigo) -->
    <Color x:Key="AccentColor">#6366F1</Color>
    <Color x:Key="AccentHoverColor">#818CF8</Color>
    <Color x:Key="AccentPressedColor">#4F46E5</Color>
    <Color x:Key="AccentSoftColor">#312E81</Color>
    <Color x:Key="AccentForegroundColor">#FFFFFF</Color>

    <!-- Drop zone -->
    <Color x:Key="DropZoneBackgroundColor">#1B2440</Color>
    <Color x:Key="DropZoneBorderColor">#4F46E5</Color>

    <!-- Inputs -->
    <Color x:Key="InputBackgroundColor">#0F172A</Color>
    <Color x:Key="InputBorderColor">#334155</Color>
    <Color x:Key="InputHoverBorderColor">#475569</Color>

    <!-- Secondary button -->
    <Color x:Key="ButtonBackgroundColor">#1E293B</Color>
    <Color x:Key="ButtonHoverBackgroundColor">#334155</Color>
    <Color x:Key="ButtonPressedBackgroundColor">#283548</Color>
    <Color x:Key="ButtonBorderColor">#3B4A61</Color>
    <Color x:Key="ButtonForegroundColor">#E2E8F0</Color>
    <Color x:Key="DisabledBackgroundColor">#1B2434</Color>
    <Color x:Key="DisabledForegroundColor">#4B5568</Color>

    <!-- Data grid -->
    <Color x:Key="GridHeaderBackgroundColor">#1A2436</Color>
    <Color x:Key="GridRowHoverColor">#273449</Color>
    <Color x:Key="GridRowSelectedColor">#312E81</Color>

    <!-- Semantic status colors -->
    <Color x:Key="SuccessColor">#4ADE80</Color>
    <Color x:Key="SuccessSoftColor">#12351F</Color>
    <Color x:Key="DangerColor">#F87171</Color>
    <Color x:Key="DangerSoftColor">#3A1B1B</Color>
    <Color x:Key="SaveColor">#2DD4BF</Color>
    <Color x:Key="SaveSoftColor">#0C3330</Color>

    <!-- Track controls -->
    <Color x:Key="TrackColor">#334155</Color>
    <Color x:Key="ThumbColor">#E2E8F0</Color>
    <Color x:Key="ScrollThumbColor">#475569</Color>
    <Color x:Key="ScrollThumbHoverColor">#64748B</Color>

    <!-- Shadow -->
    <Color x:Key="ShadowColor">#000000</Color>

    <!-- ================= Brushes ================= -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource WindowBackgroundColor}" />
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{StaticResource PanelBackgroundColor}" />
    <SolidColorBrush x:Key="ElevatedBackgroundBrush" Color="{StaticResource ElevatedBackgroundColor}" />
    <SolidColorBrush x:Key="SubtleBackgroundBrush" Color="{StaticResource SubtleBackgroundColor}" />

    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="{StaticResource MutedTextColor}" />
    <SolidColorBrush x:Key="SubtleTextBrush" Color="{StaticResource SubtleTextColor}" />

    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="DividerBrush" Color="{StaticResource DividerColor}" />

    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}" />
    <SolidColorBrush x:Key="AccentPressedBrush" Color="{StaticResource AccentPressedColor}" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="{StaticResource AccentSoftColor}" />
    <SolidColorBrush x:Key="AccentForegroundBrush" Color="{StaticResource AccentForegroundColor}" />

    <SolidColorBrush x:Key="DropZoneBackgroundBrush" Color="{StaticResource DropZoneBackgroundColor}" />
    <SolidColorBrush x:Key="DropZoneBorderBrush" Color="{StaticResource DropZoneBorderColor}" />

    <SolidColorBrush x:Key="InputBackgroundBrush" Color="{StaticResource InputBackgroundColor}" />
    <SolidColorBrush x:Key="InputBorderBrush" Color="{StaticResource InputBorderColor}" />
    <SolidColorBrush x:Key="InputHoverBorderBrush" Color="{StaticResource InputHoverBorderColor}" />

    <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="{StaticResource ButtonBackgroundColor}" />
    <SolidColorBrush x:Key="ButtonHoverBackgroundBrush" Color="{StaticResource ButtonHoverBackgroundColor}" />
    <SolidColorBrush x:Key="ButtonPressedBackgroundBrush" Color="{StaticResource ButtonPressedBackgroundColor}" />
    <SolidColorBrush x:Key="ButtonBorderBrush" Color="{StaticResource ButtonBorderColor}" />
    <SolidColorBrush x:Key="ButtonForegroundBrush" Color="{StaticResource ButtonForegroundColor}" />
    <SolidColorBrush x:Key="DisabledBackgroundBrush" Color="{StaticResource DisabledBackgroundColor}" />
    <SolidColorBrush x:Key="DisabledForegroundBrush" Color="{StaticResource DisabledForegroundColor}" />

    <SolidColorBrush x:Key="GridHeaderBackgroundBrush" Color="{StaticResource GridHeaderBackgroundColor}" />
    <SolidColorBrush x:Key="GridRowHoverBrush" Color="{StaticResource GridRowHoverColor}" />
    <SolidColorBrush x:Key="GridRowSelectedBrush" Color="{StaticResource GridRowSelectedColor}" />

    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="SuccessSoftBrush" Color="{StaticResource SuccessSoftColor}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" />
    <SolidColorBrush x:Key="DangerSoftBrush" Color="{StaticResource DangerSoftColor}" />
    <SolidColorBrush x:Key="SaveBrush" Color="{StaticResource SaveColor}" />
    <SolidColorBrush x:Key="SaveSoftBrush" Color="{StaticResource SaveSoftColor}" />

    <SolidColorBrush x:Key="TrackBrush" Color="{StaticResource TrackColor}" />
    <SolidColorBrush x:Key="ThumbBrush" Color="{StaticResource ThumbColor}" />
    <SolidColorBrush x:Key="ScrollThumbBrush" Color="{StaticResource ScrollThumbColor}" />
    <SolidColorBrush x:Key="ScrollThumbHoverBrush" Color="{StaticResource ScrollThumbHoverColor}" />
</ResourceDictionary>
