<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="WindowBackgroundColor">#111827</Color>
    <Color x:Key="PanelBackgroundColor">#1F2937</Color>
    <Color x:Key="TextColor">#F9FAFB</Color>
    <Color x:Key="MutedTextColor">#9CA3AF</Color>
    <Color x:Key="BorderColor">#374151</Color>
    <Color x:Key="AccentColor">#60A5FA</Color>
    <Color x:Key="DropZoneBackgroundColor">#172554</Color>

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource WindowBackgroundColor}" />
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{StaticResource PanelBackgroundColor}" />
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="{StaticResource MutedTextColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="DropZoneBackgroundBrush" Color="{StaticResource DropZoneBackgroundColor}" />
</ResourceDictionary>
