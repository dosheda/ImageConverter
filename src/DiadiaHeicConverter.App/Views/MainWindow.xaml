<Window x:Class="DiadiaHeicConverter.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{DynamicResource AppTitle}"
        Icon="/Resources/app.ico"
        Width="1180"
        Height="760"
        MinWidth="1040"
        MinHeight="660"
        Background="{DynamicResource WindowBackgroundBrush}"
        FontFamily="Segoe UI"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Ideal"
        AllowDrop="True"
        DragOver="OnDragOver"
        Drop="OnDrop">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource DividerBrush}"
                BorderThickness="0,0,0,1"
                Padding="18,14">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border Width="38" Height="38" CornerRadius="11"
                        Background="{DynamicResource AccentBrush}" Margin="0,0,12,0">
                    <TextBlock Text="◆" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource AccentForegroundBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{DynamicResource AppTitle}" FontSize="17" FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                        <Border Margin="10,1,0,0" Padding="8,2" CornerRadius="7"
                                Background="{DynamicResource AccentSoftBrush}" VerticalAlignment="Center">
                            <TextBlock Text="{Binding AppVersion}" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentBrush}" />
                        </Border>
                    </StackPanel>
                    <TextBlock Text="{DynamicResource DropSubtitle}" FontSize="11.5"
                               Margin="0,2,0,0" Foreground="{DynamicResource MutedTextBrush}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Body -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="336" />
            </Grid.ColumnDefinitions>

            <!-- Left content -->
            <Grid Grid.Column="0" Background="{DynamicResource WindowBackgroundBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="20,16,20,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Width="58" Height="58" CornerRadius="29"
                                Background="{DynamicResource AccentSoftBrush}"
                                Margin="0,0,18,0">
                            <Grid>
                                <Ellipse Stroke="{DynamicResource AccentBrush}" StrokeThickness="5" Margin="5" />
                                <TextBlock Text="{Binding SucceededCount}" FontSize="15" FontWeight="Bold"
                                           Foreground="{DynamicResource AccentBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,28,0">
                            <TextBlock Text="{DynamicResource StatCompleted}" FontSize="11.5"
                                       Foreground="{DynamicResource MutedTextBrush}" />
                            <TextBlock Margin="0,2,0,0">
                                <Run Text="{Binding SucceededCount, Mode=OneWay}" FontSize="21" FontWeight="Bold" />
                                <Run Text=" / " FontSize="13" Foreground="{DynamicResource SubtleTextBrush}" />
                                <Run Text="{Binding TotalCount, Mode=OneWay}" FontSize="13" Foreground="{DynamicResource SubtleTextBrush}" />
                            </TextBlock>
                        </StackPanel>

                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock Text="{Binding CurrentMessage}" FontSize="13"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       TextTrimming="CharacterEllipsis" />
                            <ProgressBar Minimum="0"
                                         Maximum="{Binding ProgressMaximum, Mode=OneWay}"
                                         Value="{Binding ProgressValue, Mode=OneWay}"
                                         Height="6" Margin="0,8,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="1" Margin="20,0,20,12"
                      MinHeight="48" AllowDrop="True"
                      DragOver="OnDragOver" Drop="OnDrop">
                    <Rectangle RadiusX="11" RadiusY="11"
                               Fill="{DynamicResource DropZoneBackgroundBrush}"
                               Stroke="{DynamicResource DropZoneBorderBrush}"
                               StrokeThickness="1.5"
                               StrokeDashArray="5 4" />
                    <Grid Margin="14,9">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Width="28" Height="28" CornerRadius="8"
                                Background="{DynamicResource AccentSoftBrush}" Margin="0,0,11,0">
                            <TextBlock Text="↑" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource DropTitle}" FontWeight="SemiBold" FontSize="12.5" />
                            <TextBlock Text="{DynamicResource InitialMessage}" FontSize="11"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Grid>
                </Grid>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Items}" Margin="14,0,14,12">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource FileRow}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="132" />
                                            <ColumnDefinition Width="92" />
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Style="{StaticResource FormatBadge}" Margin="0,0,13,0">
                                            <TextBlock Text="{Binding InputFormatLabel}" FontSize="10" FontWeight="Bold"
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" MinWidth="0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding OutputFileName}" FontSize="13.5" FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="1" Text="←" Margin="5,0"
                                                           Foreground="{DynamicResource SubtleTextBrush}" />
                                                <TextBlock Grid.Column="2" Text="{Binding SourceFileName}" FontSize="13.5"
                                                           Foreground="{DynamicResource MutedTextBrush}"
                                                           TextTrimming="CharacterEllipsis" />
                                            </Grid>
                                            <TextBlock Text="{Binding DetailDisplay}" Margin="0,3,0,0" FontSize="11"
                                                       Foreground="{DynamicResource SubtleTextBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding SizeSummaryDisplay}" FontSize="12.5"
                                                       Foreground="{DynamicResource MutedTextBrush}"
                                                       TextAlignment="Right" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding OutputPath}" Margin="0,2,0,0" FontSize="10.5"
                                                       Foreground="{DynamicResource SubtleTextBrush}"
                                                       TextAlignment="Right" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>

                                        <Border Grid.Column="3" Style="{StaticResource StatusChipBorder}"
                                                VerticalAlignment="Center" HorizontalAlignment="Right">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <Ellipse Style="{StaticResource StatusDot}" VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding StatusText}" Style="{StaticResource StatusChipText}"
                                                           Margin="6,0,0,0" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- Inspector -->
            <Border Grid.Column="1"
                    Background="{DynamicResource SubtleBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Padding="18,16" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,0,0,1">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource SectionOutput}" Style="{StaticResource InspectorSectionTitle}"
                                           Margin="0,0,0,12" />

                                <TextBlock Text="{DynamicResource OutputFormatLabel}" Style="{StaticResource FieldLabel}" />
                                <ListBox ItemsSource="{Binding OutputFormatOptions}"
                                         DisplayMemberPath="DisplayName"
                                         SelectedValuePath="Value"
                                         SelectedValue="{Binding SelectedOutputFormat, Mode=TwoWay}"
                                         Style="{StaticResource FormatPillListBox}"
                                         ItemContainerStyle="{StaticResource FormatPill}" />

                                <Grid Margin="0,8,0,7">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource JpegQualityLabel}" Style="{StaticResource FieldLabel}"
                                               Margin="0" />
                                    <TextBlock Grid.Column="1" Text="{Binding JpegQuality}" FontSize="12"
                                               FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" />
                                </Grid>
                                <Slider Minimum="1" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True"
                                        Value="{Binding JpegQuality, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Border>

                        <Border Padding="18,16" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,0,0,1">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource SectionNaming}" Style="{StaticResource InspectorSectionTitle}"
                                           Margin="0,0,0,12" />

                                <TextBlock Text="{DynamicResource NamingRuleLabel}" Style="{StaticResource FieldLabel}" />
                                <ComboBox ItemsSource="{Binding NamingRuleOptions}"
                                          DisplayMemberPath="DisplayName" SelectedValuePath="Value"
                                          SelectedValue="{Binding SelectedNamingRule, Mode=TwoWay}" />

                                <TextBlock Text="{DynamicResource OutputToLabel}" Style="{StaticResource FieldLabel}"
                                           Margin="0,14,0,7" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding OutputDirectory, UpdateSourceTrigger=PropertyChanged}"
                                             IsReadOnly="True" Margin="0,0,7,0" />
                                    <Button Grid.Column="1" Content="{DynamicResource BrowseButtonText}"
                                            Command="{Binding BrowseOutputDirectoryCommand}" MinWidth="70" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Padding="18,16" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,0,0,1">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource SectionMetadata}" Style="{StaticResource InspectorSectionTitle}"
                                           Margin="0,0,0,10" />
                                <CheckBox Content="{DynamicResource PreserveExifText}" IsChecked="{Binding PreserveExif}" />
                                <CheckBox Content="{DynamicResource PreserveGpsText}" IsChecked="{Binding PreserveGps}" />
                                <CheckBox Content="{DynamicResource PreserveDirectoryText}" IsChecked="{Binding PreserveDirectoryStructure}" />
                                <CheckBox Content="{DynamicResource OverwriteText}" IsChecked="{Binding OverwriteExistingFiles}" />
                            </StackPanel>
                        </Border>

                        <Border Padding="18,16" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,0,0,1">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource SectionAppearance}" Style="{StaticResource InspectorSectionTitle}"
                                           Margin="0,0,0,12" />

                                <TextBlock Text="{DynamicResource ThemeLabel}" Style="{StaticResource FieldLabel}" />
                                <ListBox ItemsSource="{Binding ThemeOptions}"
                                         DisplayMemberPath="DisplayName"
                                         SelectedValuePath="Value"
                                         SelectedValue="{Binding SelectedTheme, Mode=TwoWay}"
                                         Style="{StaticResource SegmentedControl}"
                                         ItemContainerStyle="{StaticResource SegmentedControlItem}" />

                                <TextBlock Text="{DynamicResource LanguageLabel}" Style="{StaticResource FieldLabel}"
                                           Margin="0,14,0,7" />
                                <ComboBox ItemsSource="{Binding LanguageOptions}"
                                          DisplayMemberPath="DisplayName" SelectedValuePath="Code"
                                          SelectedValue="{Binding SelectedLanguageCode, Mode=TwoWay}" />
                            </StackPanel>
                        </Border>

                        <Border Padding="18,16">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource SectionAbout}" Style="{StaticResource InspectorSectionTitle}"
                                           Margin="0,0,0,12" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Border Width="30" Height="30" CornerRadius="8"
                                            Background="{DynamicResource AccentBrush}" Margin="0,0,10,0">
                                        <TextBlock Text="◆" FontSize="12" FontWeight="Bold"
                                                   Foreground="{DynamicResource AccentForegroundBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{DynamicResource AppTitle}" FontWeight="SemiBold" FontSize="12.5" />
                                        <TextBlock FontSize="11" Foreground="{DynamicResource MutedTextBrush}">
                                            <Run Text="{Binding AppVersion, Mode=OneWay}" />
                                            <Run Text=" · " />
                                            <Run Text="{DynamicResource AboutMetaSuffix}" />
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>
                                <WrapPanel>
                                    <Button Content="{DynamicResource LinkGitHub}" Command="{Binding OpenGitHubCommand}"
                                            Style="{StaticResource RowActionButton}" Opacity="1" Margin="0,0,7,7" />
                                    <Button Content="{DynamicResource LinkCheckUpdate}" Command="{Binding OpenReleasesCommand}"
                                            Style="{StaticResource RowActionButton}" Opacity="1" Margin="0,0,7,7" />
                                    <Button Content="{DynamicResource LinkLicenses}" Command="{Binding OpenLicensesCommand}"
                                            Style="{StaticResource RowActionButton}" Opacity="1" Margin="0,0,7,7" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="20,13">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Margin="0,0,15,0" Foreground="{DynamicResource MutedTextBrush}">
                        <Run Text="{DynamicResource SummaryTotal}" />
                        <Run Text=" " />
                        <Run Text="{Binding TotalCount, Mode=OneWay}" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" />
                    </TextBlock>
                    <TextBlock Margin="0,0,15,0" Foreground="{DynamicResource SuccessBrush}">
                        <Run Text="{DynamicResource SummarySuccess}" />
                        <Run Text=" " />
                        <Run Text="{Binding SucceededCount, Mode=OneWay}" FontWeight="SemiBold" />
                    </TextBlock>
                    <TextBlock Margin="0,0,15,0" Foreground="{DynamicResource MutedTextBrush}">
                        <Run Text="{DynamicResource StatusPending}" />
                        <Run Text=" " />
                        <Run Text="{Binding PendingCount, Mode=OneWay}" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" />
                    </TextBlock>
                    <TextBlock Foreground="{DynamicResource DangerBrush}">
                        <Run Text="{DynamicResource SummaryFailed}" />
                        <Run Text=" " />
                        <Run Text="{Binding FailedCount, Mode=OneWay}" FontWeight="SemiBold" />
                    </TextBlock>
                </StackPanel>

                <ProgressBar Grid.Column="1" Minimum="0"
                             Maximum="{Binding ProgressMaximum, Mode=OneWay}"
                             Value="{Binding ProgressValue, Mode=OneWay}"
                             Height="6" Margin="22,0" VerticalAlignment="Center"
                             MaxWidth="260" HorizontalAlignment="Left" />

                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="{DynamicResource OpenOutputButtonText}"
                            Command="{Binding OpenOutputDirectoryCommand}"
                            MinWidth="132" Margin="0,0,10,0" />
                    <Button Style="{StaticResource PrimaryButton}"
                            Content="{Binding StartButtonText}"
                            Command="{Binding StartConversionCommand}"
                            MinWidth="150" Margin="0,0,10,0" />
                    <Button Content="{DynamicResource CancelButtonText}"
                            Command="{Binding CancelConversionCommand}"
                            MinWidth="76" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
