<Window x:Class="DiadiaHeicConverter.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:conv="clr-namespace:DiadiaHeicConverter.App.Converters"
        mc:Ignorable="d"
        Title="{DynamicResource AppTitle}"
        Width="1180"
        Height="760"
        MinWidth="980"
        MinHeight="640"
        Background="{DynamicResource WindowBackgroundBrush}"
        AllowDrop="True"
        DragOver="OnDragOver"
        Drop="OnDrop">
    <Window.Resources>
        <conv:StatusToBrushConverter x:Key="StatusToBrushConverter" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="132" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource DropZoneBackgroundBrush}"
                BorderBrush="{DynamicResource AccentBrush}"
                BorderThickness="1.5"
                CornerRadius="8"
                Padding="22"
                AllowDrop="True"
                DragOver="OnDragOver"
                Drop="OnDrop">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource DropTitle}"
                               FontSize="24"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{DynamicResource DropSubtitle}"
                               Margin="0,8,0,0"
                               FontSize="14"
                               Foreground="{DynamicResource MutedTextBrush}" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Content="{DynamicResource StartButtonText}"
                            Command="{Binding StartConversionCommand}"
                            Margin="0,0,10,0"
                            MinWidth="112" />
                    <Button Content="{DynamicResource CancelButtonText}"
                            Command="{Binding CancelConversionCommand}"
                            Margin="0,0,10,0"
                            MinWidth="84" />
                    <Button Content="{DynamicResource ClearButtonText}"
                            Command="{Binding ClearListCommand}"
                            MinWidth="96" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="0,14,0,14"
                Padding="16"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" MinWidth="260" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="220" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Text="{DynamicResource OutputDirectoryLabel}"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0" />
                <TextBox Grid.Row="0"
                         Grid.Column="1"
                         Grid.ColumnSpan="2"
                         Text="{Binding OutputDirectory, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,10,0" />
                <Button Grid.Row="0"
                        Grid.Column="3"
                        Content="{DynamicResource BrowseButtonText}"
                        Command="{Binding BrowseOutputDirectoryCommand}"
                        MinWidth="74" />

                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Text="{DynamicResource JpegQualityLabel}"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="170"
                           Margin="0,12,10,0" />
                <Grid Grid.Row="1"
                      Grid.Column="1"
                      Margin="0,12,16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="42" />
                    </Grid.ColumnDefinitions>
                    <Slider Minimum="1"
                            Maximum="100"
                            TickFrequency="1"
                            IsSnapToTickEnabled="True"
                            Value="{Binding JpegQuality, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding JpegQuality}"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center" />
                </Grid>

                <TextBlock Grid.Row="1"
                           Grid.Column="2"
                           Text="{DynamicResource OutputFormatLabel}"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="160"
                           Margin="0,12,10,0" />
                <ComboBox Grid.Row="1"
                          Grid.Column="3"
                          Margin="0,12,0,0"
                          ItemsSource="{Binding OutputFormatOptions}"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="Value"
                          SelectedValue="{Binding SelectedOutputFormat, Mode=TwoWay}" />

                <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           Text="{DynamicResource NamingRuleLabel}"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="170"
                           Margin="0,12,10,0" />
                <ComboBox Grid.Row="2"
                          Grid.Column="1"
                          Margin="0,12,16,0"
                          ItemsSource="{Binding NamingRuleOptions}"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="Value"
                          SelectedValue="{Binding SelectedNamingRule, Mode=TwoWay}" />

                <TextBlock Grid.Row="2"
                           Grid.Column="2"
                           Text="{DynamicResource LanguageLabel}"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="160"
                           Margin="0,12,10,0" />
                <ComboBox Grid.Row="2"
                          Grid.Column="3"
                          Margin="0,12,0,0"
                          ItemsSource="{Binding LanguageOptions}"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="Code"
                          SelectedValue="{Binding SelectedLanguageCode, Mode=TwoWay}" />

                <WrapPanel Grid.Row="3"
                           Grid.Column="0"
                           Grid.ColumnSpan="4"
                           Margin="0,10,0,0">
                    <CheckBox Content="{DynamicResource PreserveExifText}"
                              IsChecked="{Binding PreserveExif}" />
                    <CheckBox Content="{DynamicResource PreserveGpsText}"
                              IsChecked="{Binding PreserveGps}" />
                    <CheckBox Content="{DynamicResource PreserveDirectoryText}"
                              IsChecked="{Binding PreserveDirectoryStructure}" />
                    <CheckBox Content="{DynamicResource OverwriteText}"
                              IsChecked="{Binding OverwriteExistingFiles}" />
                </WrapPanel>

                <StackPanel Grid.Row="4"
                            Grid.Column="0"
                            Grid.ColumnSpan="4"
                            Margin="0,12,0,0">
                    <TextBlock Text="{DynamicResource PrivacyHint}"
                               Foreground="{DynamicResource MutedTextBrush}" />
                    <TextBlock Text="{DynamicResource SameFormatHint}"
                               Margin="0,4,0,0"
                               Foreground="{DynamicResource MutedTextBrush}" />
                </StackPanel>
            </Grid>
        </Border>

        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Items}"
                  EnableRowVirtualization="True"
                  EnableColumnVirtualization="True">
            <DataGrid.Columns>
                <DataGridTextColumn Binding="{Binding SourcePath}"
                                    Width="2.1*">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="{DynamicResource ColumnSource}" />
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn Binding="{Binding OutputPath}"
                                    Width="2.1*">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="{DynamicResource ColumnOutput}" />
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn Binding="{Binding FileSizeDisplay}"
                                    Width="90">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="{DynamicResource ColumnSize}" />
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn Binding="{Binding StatusText}"
                                    Width="96">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="{DynamicResource ColumnStatus}" />
                    </DataGridTextColumn.Header>
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground"
                                    Value="{Binding Status, Converter={StaticResource StatusToBrushConverter}}" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Binding="{Binding FailureReason}"
                                    Width="1.4*">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="{DynamicResource ColumnReason}" />
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="3"
                Margin="0,14,0,0"
                Padding="14"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding CurrentMessage}"
                           Foreground="{DynamicResource MutedTextBrush}" />
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <TextBlock Margin="0,0,18,0">
                        <Run Text="{DynamicResource SummaryTotal}" />
                        <Run Text=" " />
                        <Run Text="{Binding TotalCount, Mode=OneWay}" />
                    </TextBlock>
                    <TextBlock Margin="0,0,18,0">
                        <Run Text="{DynamicResource SummarySuccess}" />
                        <Run Text=" " />
                        <Run Text="{Binding SucceededCount, Mode=OneWay}" />
                    </TextBlock>
                    <TextBlock Margin="0,0,18,0">
                        <Run Text="{DynamicResource SummaryFailed}" />
                        <Run Text=" " />
                        <Run Text="{Binding FailedCount, Mode=OneWay}" />
                    </TextBlock>
                    <TextBlock>
                        <Run Text="{DynamicResource SummarySkipped}" />
                        <Run Text=" " />
                        <Run Text="{Binding SkippedCount, Mode=OneWay}" />
                    </TextBlock>
                </StackPanel>

                <ProgressBar Grid.Row="1"
                             Minimum="0"
                             Maximum="{Binding ProgressMaximum, Mode=OneWay}"
                             Value="{Binding ProgressValue, Mode=OneWay}"
                             Height="12"
                             Margin="0,12,116,0" />
                <Button Grid.Row="1"
                        Grid.Column="1"
                        Content="{DynamicResource OpenOutputButtonText}"
                        Command="{Binding OpenOutputDirectoryCommand}"
                        MinWidth="132"
                        Margin="12,8,0,0" />
            </Grid>
        </Border>
    </Grid>
</Window>
